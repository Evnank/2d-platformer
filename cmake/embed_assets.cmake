if(NOT DEFINED OUTPUT)
    message(FATAL_ERROR "OUTPUT is required")
endif()

if(NOT DEFINED MANIFEST)
    message(FATAL_ERROR "MANIFEST is required")
endif()

file(READ "${MANIFEST}" MANIFEST_CONTENT)
string(REPLACE "\r\n" "\n" MANIFEST_CONTENT "${MANIFEST_CONTENT}")
string(REPLACE "\r" "\n" MANIFEST_CONTENT "${MANIFEST_CONTENT}")
string(REPLACE "\n" ";" MANIFEST_LINES "${MANIFEST_CONTENT}")

set(GENERATED "// Generated by cmake/embed_assets.cmake. Do not edit.\n")
string(APPEND GENERATED "#include \"embedded_assets.hpp\"\n\n")
string(APPEND GENERATED "#include <string_view>\n\n")
string(APPEND GENERATED "namespace {\n\n")

set(ASSET_TABLE "")
set(ASSET_INDEX 0)

foreach(MANIFEST_LINE IN LISTS MANIFEST_LINES)
    if(MANIFEST_LINE STREQUAL "")
        continue()
    endif()

    string(FIND "${MANIFEST_LINE}" "|" SEPARATOR_INDEX)
    if(SEPARATOR_INDEX EQUAL -1)
        message(FATAL_ERROR "Invalid embedded asset manifest line: ${MANIFEST_LINE}")
    endif()

    string(SUBSTRING "${MANIFEST_LINE}" 0 ${SEPARATOR_INDEX} SOURCE_PATH)
    math(EXPR KEY_START "${SEPARATOR_INDEX} + 1")
    string(SUBSTRING "${MANIFEST_LINE}" ${KEY_START} -1 ASSET_KEY)
    string(REPLACE "\\" "\\\\" ASSET_KEY_ESCAPED "${ASSET_KEY}")
    string(REPLACE "\"" "\\\"" ASSET_KEY_ESCAPED "${ASSET_KEY_ESCAPED}")

    set(ARRAY_NAME "asset_${ASSET_INDEX}")
    file(READ "${SOURCE_PATH}" ASSET_HEX HEX)
    string(REGEX REPLACE "([0-9A-Fa-f][0-9A-Fa-f])" "0x\\1," ASSET_BYTES "${ASSET_HEX}")
    string(REGEX REPLACE "((0x[0-9A-Fa-f][0-9A-Fa-f],){24})" "\\1\n" ASSET_BYTES "${ASSET_BYTES}")

    string(APPEND GENERATED "alignas(unsigned char) const unsigned char ${ARRAY_NAME}[] = {\n")
    string(APPEND GENERATED "${ASSET_BYTES}\n")
    string(APPEND GENERATED "};\n\n")
    string(APPEND ASSET_TABLE "    {\"${ASSET_KEY_ESCAPED}\", {${ARRAY_NAME}, sizeof(${ARRAY_NAME})}},\n")

    math(EXPR ASSET_INDEX "${ASSET_INDEX} + 1")
endforeach()

string(APPEND GENERATED "struct EmbeddedAsset {\n")
string(APPEND GENERATED "    std::string_view path;\n")
string(APPEND GENERATED "    embedded_assets::AssetView view;\n")
string(APPEND GENERATED "};\n\n")
string(APPEND GENERATED "const EmbeddedAsset assets[] = {\n")
string(APPEND GENERATED "${ASSET_TABLE}")
string(APPEND GENERATED "};\n\n")
string(APPEND GENERATED "} // namespace\n\n")
string(APPEND GENERATED "namespace embedded_assets {\n\n")
string(APPEND GENERATED "std::optional<AssetView> find(std::string_view path)\n")
string(APPEND GENERATED "{\n")
string(APPEND GENERATED "    for (const auto& asset : assets) {\n")
string(APPEND GENERATED "        if (asset.path == path) {\n")
string(APPEND GENERATED "            return asset.view;\n")
string(APPEND GENERATED "        }\n")
string(APPEND GENERATED "    }\n")
string(APPEND GENERATED "    return std::nullopt;\n")
string(APPEND GENERATED "}\n\n")
string(APPEND GENERATED "} // namespace embedded_assets\n")

file(WRITE "${OUTPUT}" "${GENERATED}")
